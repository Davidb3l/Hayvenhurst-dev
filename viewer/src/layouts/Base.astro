---
// Base layout used by every page. Keeps HTML payload tiny.
//
// - Inlines global CSS via the build config (`inlineStylesheets: "always"`).
// - Ships exactly one tiny inline script for the theme toggle (no JS island).
// - No web fonts. System UI stack.
//
// Props:
//   title  — page title
//   desc   — meta description (optional)

import "~/styles/global.css";

interface Props {
  title: string;
  desc?: string;
  current?: "overview" | "graph" | "claims" | "peers" | "search";
}

const { title, desc, current } = Astro.props;
const navItems: ReadonlyArray<{ href: string; label: string; key: Props["current"] }> = [
  { href: "/", label: "Overview", key: "overview" },
  { href: "/graph", label: "Graph", key: "graph" },
  { href: "/search", label: "Search", key: "search" },
  { href: "/claims", label: "Claims", key: "claims" },
  { href: "/peers", label: "Peers", key: "peers" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Hayvenhurst</title>
    {desc && <meta name="description" content={desc} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="dark light" />
    <script is:inline>
      // Theme bootstrap — runs before paint to avoid flash.
      // 200 bytes is a tax we pay once per page; worth it.
      (function () {
        try {
          var t = localStorage.getItem("hv-theme");
          if (t === "light") document.documentElement.setAttribute("data-theme", "light");
        } catch (_) { /* private mode, ignore */ }
      })();
    </script>
  </head>
  <body>
    <a class="hv-skip-link" href="#main">Skip to main content</a>
    <nav class="hv-nav" aria-label="Primary">
      <a class="brand" href="/"><span class="dot" aria-hidden="true"></span>Hayvenhurst</a>
      <div class="links">
        {navItems.map((i) => (
          <a href={i.href} aria-current={current === i.key ? "page" : undefined}>{i.label}</a>
        ))}
      </div>
      <select id="hv-project" class="hv-project-select" aria-label="Select project" style="display:none"></select>
      <button class="hv-theme-toggle" id="hv-theme" type="button" aria-label="Toggle theme">theme</button>
    </nav>
    <main id="main">
      <slot />
    </main>
    <footer>
      <span class="mono">hayven</span> &middot; you're not alone.
    </footer>
    <script is:inline>
      (function () {
        var btn = document.getElementById("hv-theme");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var isLight = document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            try { localStorage.setItem("hv-theme", "dark"); } catch (_) {}
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            try { localStorage.setItem("hv-theme", "light"); } catch (_) {}
          }
        });
      })();
    </script>
    <script is:inline>
      // Multi-project switcher. Populates the nav <select> and keeps it LIVE: an
      // initial /api/health fetch, then a Server-Sent-Events subscription to
      // /api/projects/stream so a repo added/removed on the running daemon updates
      // the dropdown with NO manual refresh. Choice persists in
      // localStorage["hv-project"]; changing it reloads so data re-fetches for the
      // new project. Hidden unless there are 2+ projects.
      (function () {
        var sel = document.getElementById("hv-project");
        if (!sel) return;
        var changeWired = false;

        function render(h) {
          var projects = (h && Array.isArray(h.projects)) ? h.projects : [];
          var aliases = projects.map(function (p) { return p.alias; });
          var stored = "";
          try { stored = localStorage.getItem("hv-project") || ""; } catch (_) {}

          // The user's selected project was removed out from under them: repoint to
          // a valid project and reload, so the page stops showing removed/stale data
          // instead of silently drifting to whatever ends up first in the list.
          // (Guarded on aliases.length so a transiently-empty push never loops.)
          if (stored && aliases.length > 0 && aliases.indexOf(stored) === -1) {
            var fallback = (h && h.primary && aliases.indexOf(h.primary) !== -1) ? h.primary : aliases[0];
            try { localStorage.setItem("hv-project", fallback); } catch (_) {}
            location.reload();
            return;
          }

          var current = stored || (h && h.primary) || "";
          sel.innerHTML = "";
          projects.forEach(function (p) {
            var opt = document.createElement("option");
            opt.value = p.alias;
            opt.textContent = p.alias;
            if (p.alias === current) opt.selected = true;
            sel.appendChild(opt);
          });
          // Show only when there's a real choice to make.
          sel.style.display = projects.length >= 2 ? "" : "none";
          if (!changeWired) {
            changeWired = true;
            sel.addEventListener("change", function () {
              try { localStorage.setItem("hv-project", sel.value); } catch (_) {}
              location.reload();
            });
          }
        }

        // Initial snapshot — works even if SSE is unsupported/blocked.
        fetch("/api/health", { headers: { accept: "application/json" } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (h) { if (h) render(h); })
          .catch(function () { /* daemon offline — stay hidden */ });

        // Live updates: the daemon pushes the project list on every add/remove.
        try {
          if (typeof EventSource !== "undefined") {
            var es = new EventSource("/api/projects/stream");
            es.onmessage = function (e) {
              try { render(JSON.parse(e.data)); } catch (_) {}
            };
            // On error EventSource auto-reconnects; nothing to do.
          }
        } catch (_) { /* SSE unavailable — the initial fetch already ran */ }
      })();
    </script>
  </body>
</html>
