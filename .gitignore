# ---------- Bun / Node ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# Keep bun.lockb committed (Bun lockfile is binary but Bun's docs recommend committing it).
# .pnp.* artifacts from yarn berry
.pnp.*

# ---------- Rust ----------
# Build output for the hayven-native crate (and any other Rust crates).
target/
**/*.rs.bk
# We are shipping a binary, so Cargo.lock IS committed for hayven-native
# (the convention is: commit Cargo.lock for bins, ignore it for libs).
# Override below if a workspace member is a pure library:
# native/some-lib-crate/Cargo.lock

# ---------- Astro / Viewer ----------
.astro/
dist/
.output/

# ---------- TypeScript build cache ----------
*.tsbuildinfo

# ---------- Coverage / test artifacts ----------
coverage/
.nyc_output/
*.lcov

# ---------- Editors / IDEs ----------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.zed/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Env / secrets ----------
.env
.env.*
!.env.example

# ---------- Python (trace collector) ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.python-version

# ---------- Hayvenhurst runtime ----------
# If a contributor runs `hayven` at the repo root for dogfooding, we do not
# want the resulting index, traces, or claim state committed. Match the bare
# name (not just `.hayven/`) so it is ignored even before the dir exists.
.hayven
.hayven/
# `hayven init` also installs the first-party skill into `.claude/skills/`
# (a copy of `skill/hayvenhurst.md`); don't commit the dogfood copy.
.claude/skills/

# ---------- Local logs / scratch ----------
*.log
logs/
.tmp/
scratch/
