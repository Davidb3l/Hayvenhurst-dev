{
  "name": "hayvenhurst",
  "version": "0.0.6",
  "private": true,
  "description": "Open-source distributed code intelligence system for AI coding agents.",
  "license": "MIT",
  "workspaces": [
    "daemon",
    "viewer"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "daemon": "bun run --filter @hayvenhurst/daemon",
    "viewer": "bun run --filter @hayvenhurst/viewer",
    "test": "bun run --filter '@hayvenhurst/*' test",
    "typecheck": "bun run --filter '@hayvenhurst/*' typecheck",
    "build:viewer": "bun run --filter @hayvenhurst/viewer build",
    "build:daemon": "bun run --filter @hayvenhurst/daemon build"
  }
}
